DATABASE_URL=postgresql://username:password@host:5432/database_name
SESSION_SECRET=your_session_secret_here
FRONTEND_URL=https://your-frontend-domain.onrender.com
# Comma-separated allowlist of origins for CORS (include preview/staging URLs)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.onrender.com,https://your-preview-domain.onrender.com

# API Server URL - for local development
VITE_API_URL=http://localhost:3001

# Optional for future email integration
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_email@example.com
